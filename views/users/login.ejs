<% layout("/layouts/boilerplate") %>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <i class="fa-regular fa-compass auth-logo"></i>
                <h2>Welcome back</h2>
                <p>Log in to your Wanderlust account</p>
            </div>
            <form action="/login" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input name="email" id="email" type="email" class="form-control auth-input" required
                        placeholder="Enter your email" />
                    <div class="invalid-feedback">Please enter your email</div>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input name="password" id="password" type="password" class="form-control auth-input" required
                        placeholder="Enter your password" />
                    <div class="invalid-feedback">Please enter your password</div>
                </div>
                <button type="submit" class="btn auth-btn w-100">Log In</button>
            </form>
            <div class="auth-footer">
                <p>Don't have an account? <a href="/signup">Sign up</a></p>
            </div>
        </div>
    </div>