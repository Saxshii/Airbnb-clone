<% layout("/layouts/boilerplate") %>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <i class="fa-regular fa-compass auth-logo"></i>
                <h2>Create account</h2>
                <p>Join Wanderlust and start exploring</p>
            </div>
            <form action="/signup" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input name="username" id="username" type="text" class="form-control auth-input" required
                        placeholder="Choose a username" />
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please choose a username</div>
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input name="email" id="email" type="email" class="form-control auth-input" required
                        placeholder="Enter your email" />
                    <div class="invalid-feedback">Please enter a valid email</div>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input name="password" id="password" type="password" class="form-control auth-input" required
                        placeholder="Create a password (min 8 chars)" pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}"
                        title="Must be 8+ characters with uppercase, lowercase and number" />
                    <div class="invalid-feedback">Min 8 chars with uppercase, lowercase and number</div>
                </div>
                <button type="submit" class="btn auth-btn w-100">Sign Up</button>
            </form>
            <div class="auth-footer">
                <p>Already have an account? <a href="/login">Log in</a></p>
            </div>
        </div>
    </div>